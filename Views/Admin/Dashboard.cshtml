@model IEnumerable<CAFE_DELIGHT.Models.Product>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var recentOrders = ViewBag.RecentOrders as IEnumerable<CAFE_DELIGHT.Models.Order>;
}

@section Styles {
    <style>
        .cd-admin-stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .cd-admin-stat-card {
            background: #fff;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            position: relative;
        }
        .cd-admin-stat-title {
            color: #888;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 10px;
        }
        .cd-admin-stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #222;
            margin-bottom: 5px;
        }
        .cd-admin-stat-subtitle {
            font-size: 12px;
            color: #28a745;
            font-weight: 600;
            display: flex;
            align-items: center;
        }
        .cd-admin-stat-icon {
            position: absolute;
            top: 20px; right: 20px;
            background: #f5f0eb;
            width: 36px; height: 36px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 8px;
            color: #6C4A3A;
            font-size: 16px;
        }
        .cd-admin-table-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            overflow: hidden;
            border: 1px solid #f0f0f0;
        }
        .cd-admin-recent-orders-title {
            padding: 20px 0 15px 0;
            font-size: 16px;
            font-weight: 700;
            margin: 0;
            color: #333;
        }
        .cd-dash-menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 18px;
            margin-bottom: 30px;
        }
        .cd-dash-menu-card {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            border: 1px solid #f0ebe5;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .cd-dash-menu-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(108,74,58,0.12);
        }
        .cd-dash-menu-card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }
        .cd-dash-menu-card-body {
            padding: 14px 16px;
        }
        .cd-dash-menu-card-body h4 {
            margin: 0 0 4px 0;
            font-size: 14px;
            font-weight: 700;
            color: #3b2418;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .cd-dash-menu-card-body h4 .cd-dash-price {
            color: #6C4A3A;
            font-size: 14px;
            font-weight: 700;
        }
        .cd-dash-menu-card-body p {
            margin: 0;
            font-size: 12px;
            color: #9e8a78;
        }
        .cd-dash-menu-card-body .cd-dash-category {
            display: inline-block;
            margin-top: 8px;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            background: #f5f0eb;
            color: #6C4A3A;
        }
        .cd-dash-menu-card-body .cd-dash-status-badge {
            display: inline-block;
            margin-top: 6px;
            margin-left: 6px;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }
        .cd-dash-status-active { background: #e6f4ea; color: #1e8e3e; }
        .cd-dash-status-out { background: #fce8e6; color: #d93025; }
    </style>
}

<div class="cd-admin-layout">
    <aside class="cd-admin-sidebar">
        <div class="cd-admin-brand">
            <div class="cd-admin-logo">CD</div>
            <div>
                <div class="cd-admin-brand-title">Cafe Delight</div>
                <div class="cd-admin-brand-subtitle">Admin</div>
            </div>
        </div>
        <nav class="cd-admin-nav">
            <a asp-controller="Admin" asp-action="Dashboard" class="cd-admin-nav-item is-active">
                <span class="cd-admin-nav-icon">📊</span>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Admin" asp-action="Index" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">☕</span>
                <span>Products</span>
            </a>
            <a asp-controller="Admin" asp-action="Users" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">👥</span>
                <span>Users</span>
            </a>
            <a asp-controller="Admin" asp-action="Orders" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">🧾</span>
                <span>Orders</span>
            </a>
            <a asp-controller="Admin" asp-action="Settings" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">⚙️</span>
                <span>Settings</span>
            </a>
        </nav>
    </aside>

    <section class="cd-admin-main">
        <header class="cd-admin-topbar">
            <div>
                <h1 class="cd-admin-page-title">Overview</h1>
            </div>
            <div class="cd-admin-topbar-right">
                <div class="cd-admin-user-chip">
                    <div class="cd-admin-user-avatar">AU</div>
                    <span>Admin User</span>
                </div>
            </div>
        </header>

        <div class="cd-admin-stats-grid">
            <div class="cd-admin-stat-card">
                <div class="cd-admin-stat-icon">₹</div>
                <div class="cd-admin-stat-title">Total Revenue</div>
                <div class="cd-admin-stat-value" id="totalRevenue">₹@ViewBag.TotalRevenue.ToString("N0")</div>
            </div>
            <div class="cd-admin-stat-card">
                <div class="cd-admin-stat-icon">🛒</div>
                <div class="cd-admin-stat-title">Total Orders</div>
                <div class="cd-admin-stat-value" id="totalOrders">@ViewBag.OrderCount</div>
            </div>
            <div class="cd-admin-stat-card">
                <div class="cd-admin-stat-icon">📦</div>
                <div class="cd-admin-stat-title">Total Products</div>
                <div class="cd-admin-stat-value" id="totalProducts">@ViewBag.ProductCount</div>
                <div class="cd-admin-stat-subtitle" style="color: #888; font-weight: normal;">Live count</div>
            </div>
            <div class="cd-admin-stat-card">
                <div class="cd-admin-stat-icon">👥</div>
                <div class="cd-admin-stat-title">Total Users</div>
                <div class="cd-admin-stat-value" id="totalUsers">@ViewBag.UserCount</div>
            </div>
        </div>


        <h3 class="cd-admin-recent-orders-title">Recent Orders</h3>
        <div class="cd-admin-table-card">
            <div style="display:grid;grid-template-columns:2fr 3fr 1fr 1fr;padding:0.55rem 1.3rem;font-size:0.8rem;font-weight:600;color:#9b8574;border-bottom:1px solid #f7ece0;column-gap:1rem;min-width:600px;">
                <span>Order ID / Customer</span>
                <span>Items</span>
                <span>Amount</span>
                <span>Status</span>
            </div>
            <div id="dashRecentOrdersBody" style="min-width:600px;overflow-x:auto;">
                @if (recentOrders != null && recentOrders.Any())
                {
                    @foreach (var order in recentOrders)
                    {
                        <div style="display:grid;grid-template-columns:2fr 3fr 1fr 1fr;padding:0.7rem 1.3rem;font-size:0.85rem;column-gap:1rem;align-items:center;border-bottom:1px solid #f7ece0;">
                            <div>
                                <div style="font-weight:600;color:#3b2418;">#@order.OrderId</div>
                                <div style="font-size:0.75rem;color:#9e8a78;margin-top:2px;">@order.User?.FullName</div>
                            </div>
                            <div style="color:#555;font-size:0.82rem;">@(order.OrderItems?.Count ?? 0) Items</div>
                            <div style="font-weight:600;">₹@order.TotalAmount</div>
                            <div>
                                <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600; @(order.Status == "Completed" ? "background:#e6f4ea;color:#1e8e3e;" : "background:#fff3e0;color:#e65100;")">@order.Status</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="padding:1.5rem;text-align:center;color:#b89880;font-size:0.9rem;">No orders yet.</div>
                }
            </div>
        </div>


        <h3 class="cd-admin-recent-orders-title" style="margin-top:10px;">Menu Items</h3>
        <div class="cd-dash-menu-grid" id="dashMenuGrid">
            @if (Model != null && Model.Any())
            {
                @foreach (var product in Model)
                {
                    <div class="cd-dash-menu-card">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://images.pexels.com/photos/302899/pexels-photo-302899.jpeg?auto=compress&cs=tinysrgb&w=800" : product.ImageUrl)" alt="@product.ProductName" />
                        <div class="cd-dash-menu-card-body">
                            <h4>@product.ProductName <span class="cd-dash-price">₹@product.Price</span></h4>
                            <p>@product.Category?.CategoryName</p>
                            <span class="cd-dash-category">@product.Category?.CategoryName</span>
                            <span class="cd-dash-status-badge @(product.Status == "Active" ? "cd-dash-status-active" : "cd-dash-status-out")">@product.Status</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="padding:1.5rem;text-align:center;color:#b89880;font-size:0.9rem;grid-column:1/-1;">No menu items yet.</div>
            }
        </div>

    </section>
</div>
