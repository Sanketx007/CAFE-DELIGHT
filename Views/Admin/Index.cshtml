@model IEnumerable<CAFE_DELIGHT.Models.Product>
@{
    ViewData["Title"] = "Admin Panel";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="cd-admin-layout">
    <aside class="cd-admin-sidebar">
        <div class="cd-admin-brand">
            <div class="cd-admin-logo">CD</div>
            <div>
                <div class="cd-admin-brand-title">Cafe Delight</div>
                <div class="cd-admin-brand-subtitle">Admin</div>
            </div>
        </div>
        <nav class="cd-admin-nav">
            <a asp-controller="Admin" asp-action="Dashboard" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">📊</span>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Admin" asp-action="Index" class="cd-admin-nav-item is-active">
                <span class="cd-admin-nav-icon">☕</span>
                <span>Products</span>
            </a>
            <a asp-controller="Admin" asp-action="Users" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">👥</span>
                <span>Users</span>
            </a>
            <a asp-controller="Admin" asp-action="Orders" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">🧾</span>
                <span>Orders</span>
            </a>
            <a asp-controller="Admin" asp-action="Settings" class="cd-admin-nav-item">
                <span class="cd-admin-nav-icon">⚙️</span>
                <span>Settings</span>
            </a>
        </nav>
    </aside>

    <section class="cd-admin-main">
        <header class="cd-admin-topbar">
            <div>
                <h1 class="cd-admin-page-title">Manage Products</h1>
                <p class="cd-admin-page-subtitle">View and manage all cafe products.</p>
            </div>
            <div class="cd-admin-topbar-right">
                <div class="cd-admin-user-chip">
                    <div class="cd-admin-user-avatar">AU</div>
                    <span>Admin User</span>
                </div>
            </div>
        </header>

        <div class="cd-admin-toolbar">
            <div class="cd-admin-search">
                <span class="cd-admin-search-icon">🔍</span>
                <input id="productSearchInput" type="text" placeholder="Search products..." />
            </div>
            <div class="cd-admin-toolbar-actions">
                <button class="cd-admin-secondary-btn" type="button">
                    ⛃ Filter
                </button>
                <a asp-controller="Admin" asp-action="AddProduct" class="cd-admin-primary-btn">
                    + Add Product
                </a>
            </div>
        </div>

        <div class="cd-admin-table-card">
            <div class="cd-admin-table-header-row">
                <span>Product</span>
                <span>Price</span>
                <span>Status</span>
                <span class="cd-admin-table-actions-col">Actions</span>
            </div>

            @foreach (var item in Model)
            {
                <div class="cd-admin-table-row cd-admin-product-row" 
                     data-product-id="@item.ProductId" 
                     data-product-name="@item.ProductName" 
                     data-product-meta="@item.Category?.CategoryName" 
                     data-product-price="@item.Price" 
                     data-product-status="@item.Status">
                    <div class="cd-admin-product-cell">
                        <div class="cd-admin-product-thumb" style="background-image: url('@(string.IsNullOrEmpty(item.ImageUrl) ? "" : item.ImageUrl)'); background-size: cover;"></div>
                        <div>
                            <div class="cd-admin-product-name">@item.ProductName</div>
                            <div class="cd-admin-product-meta">@item.Category?.CategoryName</div>
                        </div>
                    </div>
                    <div class="cd-admin-table-text">₹@item.Price</div>
                    <div class="cd-admin-table-text">
                        <span class="cd-admin-status-pill @(item.Status == "Active" ? "is-active" : "is-out")">@item.Status</span>
                    </div>
                    <div class="cd-admin-table-actions">
                        <button type="button" class="cd-admin-icon-btn cd-admin-edit-product-btn" title="Edit">✏️</button>
                        <button type="button" class="cd-admin-icon-btn cd-admin-delete-product-btn" title="Delete">🗑</button>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

<!-- Edit Product Modal (UI only) -->
<div id="editProductModalOverlay" class="cd-admin-edit-overlay" style="display:none;">
    <div class="cd-admin-edit-modal" role="dialog" aria-modal="true" aria-labelledby="editProductModalTitle">
        <button type="button" class="cd-admin-edit-close" id="editProductModalCloseBtn">&times;</button>
        <h2 id="editProductModalTitle" class="cd-admin-edit-title">Edit Product</h2>

        <div class="cd-admin-edit-body">
            <div class="cd-admin-form-group">
                <label for="editProductName">Product Name</label>
                <input id="editProductName" class="cd-admin-form-control" type="text" readonly />
            </div>

            <div class="cd-admin-form-group">
                <label for="editProductCategory">Category</label>
                <input id="editProductCategory" class="cd-admin-form-control" type="text" />
            </div>

            <div class="cd-admin-edit-grid">
                <div class="cd-admin-form-group">
                    <label for="editProductPrice">Price</label>
                    <input id="editProductPrice" class="cd-admin-form-control" type="text" />
                </div>

                <div class="cd-admin-form-group">
                    <label for="editProductStatus">Stock Status</label>
                    <select id="editProductStatus" class="cd-admin-form-control">
                        <option value="Active">Active</option>
                        <option value="Out of Stock">Out of Stock</option>
                    </select>
                </div>
            </div>

            <div class="cd-admin-form-group" style="margin-top:0.75rem;">
                <label>Product Image</label>
                <div id="editImagePreviewBox" style="width:100%;height:110px;border-radius:8px;background:#f5ede4;border:2px dashed #d4b49a;display:flex;align-items:center;justify-content:center;margin-bottom:0.5rem;overflow:hidden;">
                    <span id="editImagePlaceholder" style="color:#b89880;font-size:0.82rem;">No image</span>
                    <img id="editImagePreviewImg" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:6px;" />
                </div>
                <div style="display:flex;gap:0.4rem;align-items:center;margin-bottom:0.4rem;">
                    <label for="editImageFile" class="cd-admin-btn-cancel" style="cursor:pointer;margin:0;padding:0.35rem 0.8rem;font-size:0.78rem;">
                        📁 Choose File
                    </label>
                    <input type="file" id="editImageFile" accept="image/*" style="display:none;" />
                    <span id="editFileLabel" style="font-size:0.78rem;color:#888;flex:1;">No file chosen</span>
                </div>
                <label style="font-size:0.78rem;color:#888;display:block;margin-bottom:0.3rem;">— or paste image URL —</label>
                <input id="editProductImageUrl" class="cd-admin-form-control" type="text" placeholder="https://example.com/image.jpg" />
            </div>

            <div class="cd-admin-form-actions cd-admin-edit-actions">
                <button type="button" class="cd-admin-btn-cancel" id="editProductCancelBtn">Cancel</button>
                <button type="button" class="cd-admin-btn-save" id="editProductSaveBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<style>
    .cd-admin-edit-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.35);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 1rem;
    }

    .cd-admin-edit-modal {
        width: 100%;
        max-width: 520px;
        background: #fff;
        border: 1px solid #f1e2d4;
        border-radius: 18px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
        padding: 1.25rem 1.4rem 1.3rem;
        position: relative;
    }

    .cd-admin-edit-close {
        position: absolute;
        top: 0.9rem;
        right: 1rem;
        border: none;
        background: transparent;
        font-size: 1.6rem;
        cursor: pointer;
        color: #a59a8c;
    }

    .cd-admin-edit-title {
        margin: 0 0 1rem;
        font-size: 1.15rem;
        font-weight: 650;
        color: #3b2418;
    }

    .cd-admin-edit-body {
        padding-top: 0.2rem;
    }

    .cd-admin-edit-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    @@media (max-width: 520px) {
        .cd-admin-edit-grid {
            grid-template-columns: 1fr;
        }
    }

    /* reuse classes from admin-panel.css */
    .cd-admin-edit-actions {
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 1px solid #f1e2d4;
    }
</style>

<script>
    (function () {
        var overlay = document.getElementById('editProductModalOverlay');
        var closeBtn = document.getElementById('editProductModalCloseBtn');
        var cancelBtn = document.getElementById('editProductCancelBtn');
        var saveBtn = document.getElementById('editProductSaveBtn');
        var searchInput = document.getElementById('productSearchInput');

        var editName = document.getElementById('editProductName');
        var editCategory = document.getElementById('editProductCategory');
        var editPrice = document.getElementById('editProductPrice');
        var editStatus = document.getElementById('editProductStatus');
        var editImageUrl = document.getElementById('editProductImageUrl');
        var editImageFile = document.getElementById('editImageFile');
        var editFileLabel = document.getElementById('editFileLabel');
        var editPreviewImg = document.getElementById('editImagePreviewImg');
        var editPlaceholder = document.getElementById('editImagePlaceholder');
        var editBase64 = '';

        function showEditPreview(src) {
            if (src && editPreviewImg) {
                editPreviewImg.src = src;
                editPreviewImg.style.display = 'block';
                if (editPlaceholder) editPlaceholder.style.display = 'none';
            } else if (editPreviewImg) {
                editPreviewImg.style.display = 'none';
                if (editPlaceholder) editPlaceholder.style.display = 'block';
            }
        }

        if (editImageFile) {
            editImageFile.addEventListener('change', function () {
                var file = editImageFile.files && editImageFile.files[0];
                if (!file) return;
                if (editFileLabel) editFileLabel.textContent = file.name;
                var reader = new FileReader();
                reader.onload = function (e) {
                    editBase64 = e.target.result;
                    if (editImageUrl) editImageUrl.value = '';
                    showEditPreview(editBase64);
                };
                reader.readAsDataURL(file);
            });
        }

        if (editImageUrl) {
            editImageUrl.addEventListener('input', function () {
                var url = editImageUrl.value.trim();
                if (url) {
                    editBase64 = '';
                    if (editFileLabel) editFileLabel.textContent = 'No file chosen';
                    if (editImageFile) editImageFile.value = '';
                    showEditPreview(url);
                } else {
                    showEditPreview('');
                }
            });
        }

        function fillModalFromRow(row) {
            editName.value = row.dataset.productName || '';
            editCategory.value = row.dataset.productMeta || '';
            editPrice.value = row.dataset.productPrice || '';
            editStatus.value = row.dataset.productStatus || 'Active';
            
            editBase64 = '';
            if (editFileLabel) editFileLabel.textContent = 'No file chosen';
            if (editImageFile) editImageFile.value = '';
            
            var currentImage = row.querySelector('.cd-admin-product-thumb').style.backgroundImage;
            if (currentImage && currentImage.startsWith('url("')) {
                currentImage = currentImage.substring(5, currentImage.length - 2);
            }
            if (editImageUrl) editImageUrl.value = currentImage;
            showEditPreview(currentImage);
        }

        function updateRowFromModal() {
            if (!activeRow) return;

            var id = activeRow.dataset.productId;
            var name = (editName.value || '').trim();
            var category = (editCategory.value || '').trim();
            var price = (editPrice.value || '').trim();
            var status = editStatus.value || 'Active';
            var image = editBase64 || (editImageUrl ? editImageUrl.value.trim() : '');

            // Call server-side action
            var formData = new FormData();
            formData.append('id', id);
            formData.append('category', category);
            formData.append('price', price);
            formData.append('status', status);
            formData.append('imageUrl', image);

            fetch('/Admin/EditProduct', {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.ok) {
                    // Update UI only if server update succeeded
                    activeRow.dataset.productName = name;
                    activeRow.dataset.productMeta = category;
                    activeRow.dataset.productPrice = price;
                    activeRow.dataset.productStatus = status;

                    var nameEl = activeRow.querySelector('.cd-admin-product-name');
                    if (nameEl) nameEl.textContent = name;

                    var metaEl = activeRow.querySelector('.cd-admin-product-meta');
                    if (metaEl) metaEl.textContent = category;

                    var textEls = activeRow.querySelectorAll('.cd-admin-table-text');
                    if (textEls && textEls.length > 0) {
                        textEls[0].textContent = '₹' + price;
                    }

                    setPillForStatus(activeRow, status);

                    if (image) {
                        var thumbEl = activeRow.querySelector('.cd-admin-product-thumb');
                        if (thumbEl) {
                            thumbEl.style.backgroundImage = 'url("' + image + '")';
                        }
                    }
                    hideOverlay();
                } else {
                    alert('Failed to update product');
                }
            });
        }

        if (saveBtn) {
            saveBtn.addEventListener('click', function () {
                updateRowFromModal();
            });
        }

        if (closeBtn) {
            closeBtn.addEventListener('click', hideOverlay);
        }

        if (cancelBtn) {
            cancelBtn.addEventListener('click', hideOverlay);
        }

        if (overlay) {
            overlay.addEventListener('click', function (e) {
                if (e.target === overlay) hideOverlay();
            });
        }

        // Search
        if (searchInput) {
            searchInput.addEventListener('input', function () {
                var q = (searchInput.value || '').toLowerCase().trim();
                var rows = document.querySelectorAll('.cd-admin-product-row');

                rows.forEach(function (row) {
                    var name = (row.dataset.productName || '').toLowerCase();
                    var meta = (row.dataset.productMeta || '').toLowerCase();
                    var status = (row.dataset.productStatus || '').toLowerCase();

                    var matches = !q || (name + ' ' + meta + ' ' + status).indexOf(q) !== -1;
                    row.style.display = matches ? '' : 'none';
                });
            });
        }

        // Edit + Delete
        var editButtons = document.querySelectorAll('.cd-admin-edit-product-btn');
        editButtons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                var row = btn.closest('.cd-admin-product-row');
                if (!row) return;
                activeRow = row;
                fillModalFromRow(row);
                showOverlay();
            });
        });

        var deleteButtons = document.querySelectorAll('.cd-admin-delete-product-btn');
        deleteButtons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                var row = btn.closest('.cd-admin-product-row');
                if (!row) return;

                var id = row.dataset.productId;
                var name = row.dataset.productName || 'this product';
                var ok = confirm('Delete "' + name + '" permanently?');
                if (!ok) return;

                var formData = new FormData();
                formData.append('id', id);

                fetch('/Admin/DeleteProduct', {
                    method: 'POST',
                    body: formData
                }).then(response => {
                    if (response.ok) {
                        if (row.parentElement) row.parentElement.removeChild(row);
                    } else {
                        alert('Failed to delete product');
                    }
                });
            });
        });
    })();
</script>
