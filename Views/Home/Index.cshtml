@model IEnumerable<CAFE_DELIGHT.Models.Product>
@{
    ViewData["Title"] = "Home";
}

<div class="cd-container cd-home">
    <section class="cd-hero">
        <div class="cd-hero-content">
            <span class="cd-hero-kicker">Warm &amp; Cozy Ambience</span>
            <h1 class="cd-hero-title">Fresh Coffee, Fresh Mood</h1>
            <p class="cd-hero-text">
                Enjoy handcrafted coffee, freshly baked pastries, and a relaxing space to work or meet friends.
            </p>
            <div class="cd-hero-actions">
                <a asp-controller="Home" asp-action="Menu" class="cd-btn cd-btn-solid">View Menu</a>
                <a asp-controller="Home" asp-action="About" class="cd-btn cd-btn-outline">About Us</a>
            </div>
        </div>
    </section>

    <section class="cd-section cd-specials">
        <div class="cd-section-header">
            <h2 class="cd-section-title">Our Specials</h2>
            <p class="cd-section-subtitle">
                A selection of our most loved drinks and treats, prepared fresh every day.
            </p>
        </div>

        <div class="cd-specials-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var product in Model)
                {
                    <article class="cd-card">
                        <div class="cd-card-image" style="background-image: url('@(string.IsNullOrEmpty(product.ImageUrl) ? "https://images.pexels.com/photos/302899/pexels-photo-302899.jpeg?auto=compress&cs=tinysrgb&w=800" : product.ImageUrl)');"></div>
                        <div class="cd-card-body">
                            <h3 class="cd-card-title">@product.ProductName</h3>
                            <p class="cd-card-text">@product.Description</p>
                            <div class="cd-card-footer">
                                <span class="cd-card-price">₹@product.Price</span>
                                <br />
                                <button type="button" class="add-btn" 
                                        data-id="@product.ProductId"
                                        data-name="@product.ProductName" 
                                        data-price="@product.Price"
                                        data-image="@product.ImageUrl"
                                        @(product.Status != "Active" ? "disabled" : "")>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 4px; vertical-align: text-bottom;"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                    @(product.Status != "Active" ? "Out of Stock" : "Add to Cart")
                                </button>
                            </div>
                        </div>
                    </article>
                }
            }
            else
            {
                <div style="padding:1.5rem;text-align:center;color:#b89880;font-size:0.9rem;grid-column:1/-1;">No specials available today.</div>
            }
        </div>
    </section>

    <section class="cd-section cd-about">
        <div class="cd-about-layout">
            <div class="cd-about-image" style="background-image: url('https://images.pexels.com/photos/1005058/pexels-photo-1005058.jpeg?auto=compress&cs=tinysrgb&w=800');"></div>
            <div class="cd-about-content">
                <h2 class="cd-section-title">About Us</h2>
                <p>
                    Cafe Delight is your neighborhood coffee spot where every cup is brewed with care.
                    From single-origin beans to freshly baked pastries, we focus on quality and comfort.
                </p>
                <p>
                    Whether you're catching up with friends, studying, or working remotely, our cozy
                    space and friendly team are here to make you feel at home.
                </p>
                <a asp-controller="Home" asp-action="About" class="cd-btn cd-btn-solid">Learn More</a>
            </div>
        </div>
    </section>
</div>

<script>
    // Integration logic for Add to Cart
    document.addEventListener('click', function(e) {
        if (e.target && (e.target.classList.contains('add-btn') || e.target.closest('.add-btn'))) {
            var btn = e.target.classList.contains('add-btn') ? e.target : e.target.closest('.add-btn');
            var productId = btn.dataset.id;
            
            if (!productId) return;

            var formData = new FormData();
            formData.append('productId', productId);
            formData.append('quantity', 1);

            fetch('/Cart/AddToCart', {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.ok) {
                    alert('Added to cart!');
                } else {
                    alert('Failed to add to cart. Try logging in.');
                }
            });
        }
    });
</script>
