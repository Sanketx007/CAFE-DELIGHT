@model IEnumerable<CAFE_DELIGHT.Models.Product>
@{
    ViewData["Title"] = "Full Menu";
    var categories = ViewBag.Categories as IEnumerable<CAFE_DELIGHT.Models.Category>;
}

<div class="full-menu-page">
    <section class="full-menu-hero">
        <div class="cd-container">
            <h1>Full Menu</h1>
            <p>Handcrafted beverages and freshly baked treats, made just for you.</p>
        </div>
    </section>

    <section class="menu-container">
        <div class="cd-container">
            <div class="menu-header">
                <div class="menu-tags">
                    <button type="button" class="active" data-category="all">All Items</button>
                    @if (categories != null)
                    {
                        @foreach (var cat in categories)
                        {
                            <button type="button" data-category="@cat.CategoryName">@cat.CategoryName</button>
                        }
                    }
                </div>
            </div>

            <div class="menu-grid">
                @if (Model != null && Model.Any())
                {
                    @foreach (var product in Model)
                    {
                        <div class="menu-card" data-category="@product.Category?.CategoryName">
                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://images.pexels.com/photos/302899/pexels-photo-302899.jpeg?auto=compress&cs=tinysrgb&w=800" : product.ImageUrl)"
                                 alt="@product.ProductName" />
                            <div class="menu-card-body">
                                <h3>@product.ProductName <span class="price">₹@product.Price</span></h3>
                                <p>@product.Description</p>
                                <button type="button" class="add-btn" 
                                        data-id="@product.ProductId"
                                        data-name="@product.ProductName" 
                                        data-price="@product.Price"
                                        data-image="@product.ImageUrl"
                                        @(product.Status != "Active" ? "disabled" : "")>
                                    @if (product.Status != "Active")
                                    {
                                        <span>Out of Stock</span>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 4px; vertical-align: text-bottom;"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                                        <span>Add to Cart</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="padding:1.5rem;text-align:center;color:#b89880;font-size:0.9rem;grid-column:1/-1;">No menu items found.</div>
                }
            </div>
        </div>
    </section>
</div>

<script>
    // Filtering logic
    document.querySelectorAll('.menu-tags button').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelector('.menu-tags button.active').classList.remove('active');
            btn.classList.add('active');
            
            const category = btn.dataset.category;
            document.querySelectorAll('.menu-card').forEach(card => {
                if (category === 'all' || card.dataset.category === category) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    });

    // Add to Cart logic
    document.addEventListener('click', function(e) {
        if (e.target && (e.target.classList.contains('add-btn') || e.target.closest('.add-btn'))) {
            var btn = e.target.classList.contains('add-btn') ? e.target : e.target.closest('.add-btn');
            var productId = btn.dataset.id;
            
            if (!productId) return;

            var formData = new FormData();
            formData.append('productId', productId);
            formData.append('quantity', 1);

            fetch('/Cart/AddToCart', {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.ok) {
                    alert('Added to cart!');
                } else {
                    alert('Failed to add to cart. Try logging in.');
                }
            });
        }
    });
</script>
